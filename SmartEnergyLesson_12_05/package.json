{
  "name": "smart-energy-control-center-full",
  "version": "2.0.0",
  "description": "Fullstack smart energy control center with MySQL, Coolify, metrics, logs and tests",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "node init-db.js",
    "test": "node --test test/",
    "test:coverage": "node --test test/ --coverage",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix --audit-level=high",
    "security-check": "npm audit --audit-level=high && npm test",
    "lint": "echo 'No linter configured yet'"
  },
  "dependencies": {
    "bcryptjs": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-session": "latest",
    "mysql2": "latest",
    "prom-client": "latest",
    "ws": "latest",
    "winston": "latest"
  },
  "devDependencies": {
    "nodemon": "latest"
  }
}
